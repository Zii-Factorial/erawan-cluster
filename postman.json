    {
      "name": "Cluster - MySQL",
      "item": [
        {
          "name": "Deploy",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Auto-extract JOB_ID from plain-JSON deploy response (no encryption)",
                  "const encryptionKey = pm.variables.get('ENCRYPTION_KEY');",
                  "if (encryptionKey && encryptionKey.trim() !== '') { return; }",
                  "try {",
                  "    const body = pm.response.json();",
                  "    if (body && body.data && body.data.id) {",
                  "        pm.collectionVariables.set('JOB_ID', body.data.id);",
                  "        console.log('[erawan] JOB_ID set to:', body.data.id);",
                  "    }",
                  "} catch(e) {}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"cluster_name\": \"{{CLUSTER_NAME}}\",\n  \"admin_username\": \"clusteradmin\",\n  \"admin_password\": \"\",\n  \"primary_ip\": \"{{PRIMARY_IP}}\",\n  \"standby_ips\": [\"{{SECONDARY_IP}}\"],\n  \"new_user\": \"{{NEW_USER}}\",\n  \"new_user_password\": \"{{NEW_USER_PASSWORD}}\",\n  \"new_user_ssl_required\": {{NEW_USER_SSL_REQUIRED}},\n  \"new_db\": \"{{NEW_DB}}\",\n  \"assume_prepared\": false,\n  \"bootstrap_router\": true,\n  \"ssh_port\": 22,\n  \"mysql_port\": 3306,\n  \"step_timeout_seconds\": 900\n}"
            },
            "description": "Starts a MySQL InnoDB Cluster deployment. Returns a job immediately (202 Accepted). Poll 'Get Job' to track progress.\n\nJOB_ID is auto-extracted from the response and stored as a collection variable.",
            "url": {
              "raw": "http://{{API_HOST}}:{{API_PORT}}/cluster/mysql/deploy",
              "protocol": "http",
              "host": ["{{API_HOST}}"],
              "port": "{{API_PORT}}",
              "path": ["cluster", "mysql", "deploy"]
            }
          }
        },
