          }
        },
        {
          "name": "Resume Job",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"cluster_admin_password\": \"\",\n  \"new_user_password\": \"{{NEW_USER_PASSWORD}}\"\n}"
            },
            "description": "Resumes a failed MySQL cluster job from the last completed step.\n\n- `cluster_admin_password` — leave empty to reuse the password stored from the original deploy\n- `new_user_password` — required when the job has a `new_user`",
            "url": {
              "raw": "http://{{API_HOST}}:{{API_PORT}}/cluster/mysql/jobs/{{JOB_ID}}/resume",
              "protocol": "http",
              "host": ["{{API_HOST}}"],
              "port": "{{API_PORT}}",
              "path": ["cluster", "mysql", "jobs", "{{JOB_ID}}", "resume"]
            }
          }
        },
        {
          "name": "Rollback Job",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"cluster_admin_password\": \"\"\n}"
            },
            "description": "Runs the rollback playbook to undo a failed MySQL cluster deployment.\n\n- `cluster_admin_password` — leave empty to reuse the password stored from the original deploy",
            "url": {
              "raw": "http://{{API_HOST}}:{{API_PORT}}/cluster/mysql/jobs/{{JOB_ID}}/rollback",
              "protocol": "http",
              "host": ["{{API_HOST}}"],
              "port": "{{API_PORT}}",
              "path": ["cluster", "mysql", "jobs", "{{JOB_ID}}", "rollback"]
            }
          }
        }
      ]
