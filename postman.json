{
  "info": {
    "_postman_id": "0f487bb5-3f07-49a9-9b29-e468f795d8d5",
    "name": "Erawan Cluster API (Go)",
    "description": "Postman collection for HAProxy, MySQL cluster, and PostgreSQL cluster endpoints.\n\n**Required variables — fill these in Collection > Variables before sending any request:**\n- `API_KEY` — sent as `X-API-Key` header on every request (collection auth)\n- `ENCRYPTION_KEY` — 64-char hex string (AES-256-GCM). When set the pre-request script encrypts every request body automatically. Generate with: `openssl rand -hex 32`\n\nLeave `ENCRYPTION_KEY` empty to send plain JSON (development only).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "apikey",
    "apikey": [
      { "key": "key", "value": "X-API-Key", "type": "string" },
      { "key": "value", "value": "{{API_KEY}}", "type": "string" },
      { "key": "in", "value": "header", "type": "string" }
    ]
  },
  "variable": [
    { "key": "API_HOST", "value": "127.0.0.1", "description": "API server host" },
    { "key": "API_PORT", "value": "8080", "description": "API server port" },
    { "key": "API_KEY", "value": "", "description": "[REQUIRED] API key — sent as X-API-Key header on every request" },
    { "key": "ENCRYPTION_KEY", "value": "", "description": "[REQUIRED] 64-char hex string (32 bytes, AES-256-GCM). Generate: openssl rand -hex 32. Leave empty for plain JSON (dev only)." },
    { "key": "JOB_ID", "value": "", "description": "Job ID — copy from a Deploy or List Jobs response" },
    { "key": "PRIMARY_IP", "value": "192.168.122.154" },
    { "key": "SECONDARY_IP", "value": "192.168.122.111" },
    { "key": "CLUSTER_NAME", "value": "prodCluster" },
    { "key": "NEW_USER", "value": "appuser" },
    { "key": "NEW_USER_PASSWORD", "value": "AppUser#2026" },
    { "key": "NEW_USER_SSL_REQUIRED", "value": "true" },
    { "key": "NEW_DB", "value": "appdb" },
    { "key": "PGSQL_PRIMARY_IP", "value": "10.0.0.1" },
    { "key": "PGSQL_STANDBY_IP_1", "value": "10.0.0.2" },
    { "key": "PGSQL_STANDBY_IP_2", "value": "10.0.0.3" },
    { "key": "PATRONI_ADMIN_PASSWORD", "value": "adminpassword", "disabled": true }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Payload Encryption — AES-256-GCM",
          "// Runs automatically for every request that has a raw JSON body.",
          "// Set ENCRYPTION_KEY (64 hex chars) to enable; leave empty for plain JSON.",
          "",
          "const encryptionKey = pm.collectionVariables.get('ENCRYPTION_KEY');",
          "if (!encryptionKey || encryptionKey.trim() === '') {",
          "    console.warn('[erawan] ENCRYPTION_KEY is not set — sending plain JSON (dev mode)');",
          "    return;",
          "}",
          "",
          "const method = pm.request.method.toUpperCase();",
          "const hasBody = pm.request.body && pm.request.body.raw && pm.request.body.raw.trim() !== '';",
          "if (!hasBody || method === 'GET' || method === 'HEAD') {",
          "    return;",
          "}",
          "",
          "const crypto = require('crypto');",
          "const key = Buffer.from(encryptionKey.trim(), 'hex');",
          "if (key.length !== 32) {",
          "    console.error('[erawan] ENCRYPTION_KEY must be 64 hex chars (32 bytes) — request NOT encrypted');",
          "    return;",
          "}",
          "",
          "const plaintext = Buffer.from(pm.request.body.raw, 'utf8');",
          "const nonce = crypto.randomBytes(12);",
          "const cipher = crypto.createCipheriv('aes-256-gcm', key, nonce);",
          "const encrypted = Buffer.concat([cipher.update(plaintext), cipher.final()]);",
          "const tag = cipher.getAuthTag();",
          "",
          "// Format: nonce(12) + ciphertext + tag(16) — matches Go's aead.Seal",
          "const payload = Buffer.concat([nonce, encrypted, tag]);",
          "const data = payload.toString('base64').replace(/\\+/g, '-').replace(/\\//g, '_');",
          "",
          "pm.request.body.update(JSON.stringify({ data: data }));",
          "console.log('[erawan] payload encrypted (' + plaintext.length + ' → ' + payload.length + ' bytes)');"
        ]
      }
    }
  ],
  "item": [
