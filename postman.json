  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Request Encryption — AES-256-GCM",
          "// Runs automatically for every request that has a raw JSON body.",
          "// Set ENCRYPTION_KEY (64 hex chars) to enable; leave empty for plain JSON.",
          "",
          "const encryptionKey = pm.variables.get('ENCRYPTION_KEY');",
          "if (!encryptionKey || encryptionKey.trim() === '') {",
          "    console.warn('[erawan] ENCRYPTION_KEY is not set — sending plain JSON (dev mode)');",
          "    return;",
          "}",
          "",
          "const method = pm.request.method.toUpperCase();",
          "const hasBody = pm.request.body && pm.request.body.raw && pm.request.body.raw.trim() !== '';",
          "if (!hasBody || method === 'GET' || method === 'HEAD') {",
          "    return;",
          "}",
          "",
          "const keyHex = encryptionKey.trim();",
          "if (keyHex.length !== 64) {",
          "    console.error('[erawan] ENCRYPTION_KEY must be 64 hex chars (32 bytes) — request NOT encrypted');",
          "    return;",
          "}",
          "",
          "(async () => {",
          "    const keyBytes = new Uint8Array(keyHex.match(/.{2}/g).map(b => parseInt(b, 16)));",
          "    const nonce = crypto.getRandomValues(new Uint8Array(12));",
          "    const plaintext = new TextEncoder().encode(pm.variables.replaceIn(pm.request.body.raw));",
          "    const cryptoKey = await crypto.subtle.importKey('raw', keyBytes, { name: 'AES-GCM' }, false, ['encrypt']);",
          "    const encrypted = await crypto.subtle.encrypt({ name: 'AES-GCM', iv: nonce }, cryptoKey, plaintext);",
          "    const payload = new Uint8Array(12 + encrypted.byteLength);",
          "    payload.set(nonce);",
          "    payload.set(new Uint8Array(encrypted), 12);",
          "    let bin = '';",
          "    payload.forEach(b => bin += String.fromCharCode(b));",
          "    const data = btoa(bin).replace(/\\+/g, '-').replace(/\\//g, '_');",
          "    pm.request.body.update(JSON.stringify({ data }));",
          "    console.log('[erawan] request encrypted (' + plaintext.length + ' → ' + payload.length + ' bytes)');",
          "})()"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Response Decryption — AES-256-GCM",
          "// Runs automatically after every response.",
          "// When ENCRYPTION_KEY is set the server returns {\"data\":\"<encrypted>\"};",
          "// this script decrypts it, logs to console, and stores in LAST_RESPONSE.",
          "",
          "const encryptionKey = pm.variables.get('ENCRYPTION_KEY');",
          "if (!encryptionKey || encryptionKey.trim() === '') {",
          "    return;",
          "}",
          "",
          "const ct = pm.response.headers.get('Content-Type') || '';",
          "if (!ct.includes('application/json')) {",
          "    // Binary response (e.g. zip download) — nothing to decrypt",
          "    return;",
          "}",
          "",
          "let body;",
          "try { body = pm.response.json(); } catch(e) { return; }",
          "if (!body || typeof body.data !== 'string') {",
          "    return;",
          "}",
          "",
          "(async () => {",
          "    try {",
          "        const keyHex = encryptionKey.trim();",
          "        if (keyHex.length !== 64) {",
          "            console.error('[erawan] ENCRYPTION_KEY must be 64 hex chars — response NOT decrypted');",
          "            return;",
          "        }",
          "        const keyBytes = new Uint8Array(keyHex.match(/.{2}/g).map(b => parseInt(b, 16)));",
          "        const b64 = body.data.replace(/-/g, '+').replace(/_/g, '/');",
          "        const binary = atob(b64);",
          "        const payload = new Uint8Array(binary.length);",
          "        for (let i = 0; i < binary.length; i++) payload[i] = binary.charCodeAt(i);",
          "        const nonce = payload.slice(0, 12);",
          "        const ciphertextWithTag = payload.slice(12);",
          "        const cryptoKey = await crypto.subtle.importKey('raw', keyBytes, { name: 'AES-GCM' }, false, ['decrypt']);",
          "        const dec = await crypto.subtle.decrypt({ name: 'AES-GCM', iv: nonce }, cryptoKey, ciphertextWithTag);",
          "        const json = JSON.parse(new TextDecoder().decode(dec));",
          "        pm.collectionVariables.set('LAST_RESPONSE', JSON.stringify(json, null, 2));",
          "        console.log('[erawan] response decrypted:', JSON.stringify(json, null, 2));",
          "        if (json && json.data && json.data.id) {",
          "            pm.collectionVariables.set('JOB_ID', json.data.id);",
          "            console.log('[erawan] JOB_ID set to:', json.data.id);",
          "        }",
          "        if (json && json.data && json.data.secret) {",
          "            const s = json.data.secret;",
          "            if (s.admin_user) { pm.collectionVariables.set('MYSQL_DB_USER', s.admin_user); console.log('[erawan] MYSQL_DB_USER set to:', s.admin_user); }",
          "            if (s.admin_password) { pm.collectionVariables.set('MYSQL_DB_PASSWORD', s.admin_password); console.log('[erawan] MYSQL_DB_PASSWORD captured'); }",
          "            if (s.postgres_user) { pm.collectionVariables.set('PGSQL_DB_USER', s.postgres_user); console.log('[erawan] PGSQL_DB_USER set to:', s.postgres_user); }",
          "            if (s.postgres_password) { pm.collectionVariables.set('PGSQL_DB_PASSWORD', s.postgres_password); console.log('[erawan] PGSQL_DB_PASSWORD captured'); }",
          "        }",
          "    } catch(e) {",
          "        console.warn('[erawan] response decryption failed:', e.message);",
          "    }",
          "})()"
        ]
      }
    }
  ],
