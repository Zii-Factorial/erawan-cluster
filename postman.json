{
  "info": {
    "_postman_id": "0f487bb5-3f07-49a9-9b29-e468f795d8d5",
    "name": "Erawan Cluster API (Go)",
    "description": "Postman collection for HAProxy, MySQL cluster, and PostgreSQL cluster endpoints.\n\n**Required variables — fill these in Collection > Variables before sending any request:**\n- `API_KEY` — sent as `X-API-Key` header on every request (collection auth)\n- `ENCRYPTION_KEY` — 64-char hex string (AES-256-GCM). When set the pre-request script encrypts every request body and the test script decrypts every JSON response automatically. Generate with: `openssl rand -hex 32`\n\nLeave `ENCRYPTION_KEY` empty to send/receive plain JSON (development only).\n\n**Decrypted responses** are logged to the Postman console and stored in the `LAST_RESPONSE` collection variable for inspection.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "apikey",
    "apikey": [
      { "key": "key", "value": "X-API-Key", "type": "string" },
      { "key": "value", "value": "{{API_KEY}}", "type": "string" },
      { "key": "in", "value": "header", "type": "string" }
    ]
  },
  "variable": [
    { "key": "API_HOST", "value": "127.0.0.1", "description": "API server host" },
    { "key": "API_PORT", "value": "8080", "description": "API server port" },
    { "key": "API_KEY", "value": "", "description": "[REQUIRED] API key — sent as X-API-Key header on every request" },
    { "key": "ENCRYPTION_KEY", "value": "", "description": "[REQUIRED] 64-char hex string (32 bytes, AES-256-GCM). Generate: openssl rand -hex 32. Leave empty for plain JSON (dev only)." },
    { "key": "JOB_ID", "value": "", "description": "Job ID — auto-filled from Deploy response, or copy manually from List Jobs" },
    { "key": "LAST_RESPONSE", "value": "", "description": "Last decrypted JSON response — inspect after any request when ENCRYPTION_KEY is set" },
    { "key": "PRIMARY_IP", "value": "192.168.122.154" },
    { "key": "SECONDARY_IP", "value": "192.168.122.111" },
    { "key": "CLUSTER_NAME", "value": "prodCluster" },
    { "key": "NEW_USER", "value": "appuser" },
    { "key": "NEW_USER_PASSWORD", "value": "AppUser#2026" },
    { "key": "NEW_USER_SSL_REQUIRED", "value": "true" },
    { "key": "NEW_DB", "value": "appdb" },
    { "key": "PGSQL_PRIMARY_IP", "value": "10.0.0.1" },
    { "key": "PGSQL_STANDBY_IP_1", "value": "10.0.0.2" },
    { "key": "PGSQL_STANDBY_IP_2", "value": "10.0.0.3" },
    { "key": "PATRONI_ADMIN_PASSWORD", "value": "adminpassword", "disabled": true }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Request Encryption — AES-256-GCM",
          "// Runs automatically for every request that has a raw JSON body.",
          "// Set ENCRYPTION_KEY (64 hex chars) to enable; leave empty for plain JSON.",
          "",
          "const encryptionKey = pm.collectionVariables.get('ENCRYPTION_KEY');",
          "if (!encryptionKey || encryptionKey.trim() === '') {",
          "    console.warn('[erawan] ENCRYPTION_KEY is not set — sending plain JSON (dev mode)');",
          "    return;",
          "}",
          "",
          "const method = pm.request.method.toUpperCase();",
          "const hasBody = pm.request.body && pm.request.body.raw && pm.request.body.raw.trim() !== '';",
          "if (!hasBody || method === 'GET' || method === 'HEAD') {",
          "    return;",
          "}",
          "",
          "const crypto = require('crypto');",
          "const key = Buffer.from(encryptionKey.trim(), 'hex');",
          "if (key.length !== 32) {",
          "    console.error('[erawan] ENCRYPTION_KEY must be 64 hex chars (32 bytes) — request NOT encrypted');",
          "    return;",
          "}",
          "",
          "const plaintext = Buffer.from(pm.request.body.raw, 'utf8');",
          "const nonce = crypto.randomBytes(12);",
          "const cipher = crypto.createCipheriv('aes-256-gcm', key, nonce);",
          "const encrypted = Buffer.concat([cipher.update(plaintext), cipher.final()]);",
          "const tag = cipher.getAuthTag();",
          "",
          "// Format: nonce(12) + ciphertext + tag(16) — matches Go's aead.Seal",
          "const payload = Buffer.concat([nonce, encrypted, tag]);",
          "const data = payload.toString('base64').replace(/\\+/g, '-').replace(/\\//g, '_');",
          "",
          "pm.request.body.update(JSON.stringify({ data: data }));",
          "console.log('[erawan] request encrypted (' + plaintext.length + ' → ' + payload.length + ' bytes)');"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Response Decryption — AES-256-GCM",
          "// Runs automatically after every response.",
          "// When ENCRYPTION_KEY is set the server returns {\"data\":\"<encrypted>\"};",
          "// this script decrypts it, logs to console, and stores in LAST_RESPONSE.",
          "",
          "const encryptionKey = pm.collectionVariables.get('ENCRYPTION_KEY');",
          "if (!encryptionKey || encryptionKey.trim() === '') {",
          "    return;",
          "}",
          "",
          "const ct = pm.response.headers.get('Content-Type') || '';",
          "if (!ct.includes('application/json')) {",
          "    // Binary response (e.g. zip download) — nothing to decrypt",
          "    return;",
          "}",
          "",
          "let body;",
          "try { body = pm.response.json(); } catch(e) { return; }",
          "if (!body || typeof body.data !== 'string') {",
          "    return;",
          "}",
          "",
          "try {",
          "    const crypto = require('crypto');",
          "    const key = Buffer.from(encryptionKey.trim(), 'hex');",
          "    if (key.length !== 32) {",
          "        console.error('[erawan] ENCRYPTION_KEY must be 64 hex chars — response NOT decrypted');",
          "        return;",
          "    }",
          "",
          "    // base64url → base64 → bytes",
          "    const b64 = body.data.replace(/-/g, '+').replace(/_/g, '/');",
          "    const payload = Buffer.from(b64, 'base64');",
          "",
          "    // Format: nonce(12) + ciphertext + tag(16) — matches Go's aead.Seal",
          "    const nonce = payload.slice(0, 12);",
          "    const tag   = payload.slice(payload.length - 16);",
          "    const ciphertext = payload.slice(12, payload.length - 16);",
          "",
          "    const decipher = crypto.createDecipheriv('aes-256-gcm', key, nonce);",
          "    decipher.setAuthTag(tag);",
          "    const plain = Buffer.concat([decipher.update(ciphertext), decipher.final()]);",
          "    const decrypted = JSON.parse(plain.toString('utf8'));",
          "",
          "    pm.collectionVariables.set('LAST_RESPONSE', JSON.stringify(decrypted, null, 2));",
          "    console.log('[erawan] response decrypted:', JSON.stringify(decrypted, null, 2));",
          "",
          "    // Auto-extract JOB_ID from deploy responses",
          "    if (decrypted && decrypted.data && decrypted.data.id) {",
          "        pm.collectionVariables.set('JOB_ID', decrypted.data.id);",
          "        console.log('[erawan] JOB_ID set to:', decrypted.data.id);",
          "    }",
          "} catch(e) {",
          "    console.warn('[erawan] response decryption failed:', e.message);",
          "}"
        ]
      }
    }
  ],
