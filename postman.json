    {
      "name": "Cluster - MySQL",
      "item": [
        {
          "name": "Deploy",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Auto-extract JOB_ID and credentials from deploy response (no encryption)",
                  "const encryptionKey = pm.variables.get('ENCRYPTION_KEY');",
                  "if (encryptionKey && encryptionKey.trim() !== '') { return; }",
                  "try {",
                  "    const body = pm.response.json();",
                  "    if (body && body.data) {",
                  "        if (body.data.id) {",
                  "            pm.collectionVariables.set('JOB_ID', body.data.id);",
                  "            console.log('[erawan] JOB_ID set to:', body.data.id);",
                  "        }",
                  "        if (body.data.secret) {",
                  "            const s = body.data.secret;",
                  "            if (s.admin_user) {",
                  "                pm.collectionVariables.set('MYSQL_DB_USER', s.admin_user);",
                  "                console.log('[erawan] MYSQL_DB_USER set to:', s.admin_user);",
                  "            }",
                  "            if (s.admin_password) {",
                  "                pm.collectionVariables.set('MYSQL_DB_PASSWORD', s.admin_password);",
                  "                console.log('[erawan] MYSQL_DB_PASSWORD captured');",
                  "            }",
                  "        }",
                  "    }",
                  "} catch(e) {}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "options": {
                "raw": {
                  "language": "json"
                }
              },
              "raw": "{\n  \"cluster_name\": \"{{CLUSTER_NAME}}\",\n  \"admin_username\": \"clusteradmin\",\n  \"admin_password\": \"\",\n  \"primary_ip\": \"{{PRIMARY_IP}}\",\n  \"standby_ips\": [\"{{SECONDARY_IP}}\"],\n  \"new_user\": \"{{NEW_USER}}\",\n  \"new_user_password\": \"{{NEW_USER_PASSWORD}}\",\n  \"new_user_ssl_required\": {{NEW_USER_SSL_REQUIRED}},\n  \"new_db\": \"{{NEW_DB}}\",\n  \"assume_prepared\": false,\n  \"bootstrap_router\": true,\n  \"ssh_port\": 22,\n  \"mysql_port\": 3306,\n  \"mysql_version\": 8,\n  \"step_timeout_seconds\": 900\n}"
            },
            "description": "Starts a MySQL InnoDB Cluster deployment. Returns a job immediately (202 Accepted). Poll 'Get Job' to track progress.\n\nJOB_ID is auto-extracted from the response and stored as a collection variable.",
            "url": {
              "raw": "http://{{API_HOST}}:{{API_PORT}}/cluster/mysql/deploy",
              "protocol": "http",
              "host": [
                "{{API_HOST}}"
              ],
              "port": "{{API_PORT}}",
              "path": [
                "cluster",
                "mysql",
                "deploy"
              ]
            }
          }
        },
        {
          "name": "Collect Metrics",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "options": {
                "raw": {
                  "language": "json"
                }
              },
              "raw": "{\n  \"port\": {{MYSQL_PROXY_PORT}},\n  \"user\": \"{{MYSQL_DB_USER}}\",\n  \"password\": \"{{MYSQL_DB_PASSWORD}}\",\n  \"ssl_mode\": \"disable\",\n  \"connect_timeout\": 10,\n  \"categories\": [],\n  \"databases\": [],\n  \"limit\": 20\n}"
            },
            "url": {
              "raw": "{{API_HOST}}:{{API_PORT}}/cluster/mysql/metrics",
              "host": [
                "{{API_HOST}}:{{API_PORT}}"
              ],
              "path": [
                "cluster",
                "mysql",
                "metrics"
              ]
            },
            "description": "Collects live metrics from a running MySQL InnoDB Cluster.\n\n**Required:** `user`\n\n**Connection routing:**\n- `host` (optional) — HAProxy or MySQL Router address; defaults to `PROXY_HOST` env var on the server (usually `127.0.0.1`)\n- `port` — HAProxy listen port for MySQL R/W traffic (e.g. 25010)\n\n**Optional:** `host`, `port` (default 3306), `password`, `database` (default `information_schema`), `ssl_mode` (`disable`|`require`, default `disable`), `connect_timeout` (seconds, default 10), `limit` (top-N for slow queries/digest lists, default 20), `from`/`to` (ISO 8601, filter slow queries)\n\n**`databases`** — optional list of database names to filter per-database results (connections by_database, slow queries, full-scan digests, fragmented tables). Empty array = all user databases. Response always includes `database_count` (total user databases on the server).\n\n**`categories`** — empty array returns all 7; pick any subset:\n- `cluster` — Group Replication membership, primary election, node states\n- `uptime` — MySQL server process uptime\n- `connections` — active/sleeping threads, utilisation, per-database breakdown\n- `replication` — GR member certification stats and applier worker lag\n- `performance` — InnoDB buffer-pool hit ratio, QPS/TPS, temp-table and sort pressure\n- `query` — Digest stats from performance_schema, slow queries, full-scan digests\n- `maintenance` — InnoDB purge lag, table fragmentation, metadata locks"
          },
          "response": []
        },
        {
          "name": "List Jobs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://{{API_HOST}}:{{API_PORT}}/cluster/mysql/jobs?limit=20",
              "protocol": "http",
              "host": [
                "{{API_HOST}}"
              ],
              "port": "{{API_PORT}}",
              "path": [
                "cluster",
                "mysql",
                "jobs"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "20"
                }
              ]
            }
          }
        },
        {
          "name": "Get Job",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Auto-extract credentials from plain-JSON get-job response (no encryption)",
                  "const encryptionKey = pm.variables.get('ENCRYPTION_KEY');",
                  "if (encryptionKey && encryptionKey.trim() !== '') { return; }",
                  "try {",
                  "    const body = pm.response.json();",
                  "    if (body && body.data && body.data.secret) {",
                  "        const s = body.data.secret;",
                  "        if (s.admin_user) { pm.collectionVariables.set('MYSQL_DB_USER', s.admin_user); console.log('[erawan] MYSQL_DB_USER set to:', s.admin_user); }",
                  "        if (s.admin_password) { pm.collectionVariables.set('MYSQL_DB_PASSWORD', s.admin_password); console.log('[erawan] MYSQL_DB_PASSWORD captured'); }",
                  "    }",
                  "} catch(e) {}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://{{API_HOST}}:{{API_PORT}}/cluster/mysql/jobs/{{JOB_ID}}",
              "protocol": "http",
              "host": [
                "{{API_HOST}}"
              ],
              "port": "{{API_PORT}}",
              "path": [
                "cluster",
                "mysql",
                "jobs",
                "{{JOB_ID}}"
              ]
            }
          }
        },
        {
          "name": "Resume Job",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "options": {
                "raw": {
                  "language": "json"
                }
              },
              "raw": "{\n  \"admin_password\": \"\",\n  \"new_user_password\": \"{{NEW_USER_PASSWORD}}\"\n}"
            },
            "description": "Resumes a failed MySQL cluster job from the last completed step.\n\n- `admin_password` — leave empty to reuse the password stored from the original deploy\n- `new_user_password` — required when the job has a `new_user`",
            "url": {
              "raw": "http://{{API_HOST}}:{{API_PORT}}/cluster/mysql/jobs/{{JOB_ID}}/resume",
              "protocol": "http",
              "host": [
                "{{API_HOST}}"
              ],
              "port": "{{API_PORT}}",
              "path": [
                "cluster",
                "mysql",
                "jobs",
                "{{JOB_ID}}",
                "resume"
              ]
            }
          }
        },
        {
          "name": "Rollback Job",
