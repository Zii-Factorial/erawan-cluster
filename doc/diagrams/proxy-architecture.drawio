<mxfile compressed="false">
  <diagram name="Proxy Architecture" id="proxy-arch">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="erawan-cluster — Proxy Architecture" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=22;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="327" y="20" width="1000" height="50" as="geometry" />
        </mxCell>

        <!-- Client -->
        <mxCell id="client" value="&lt;b&gt;Client Application&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="677" y="90" width="300" height="70" as="geometry" />
        </mxCell>

        <!-- ===== PROXY NODE CONTAINER ===== -->
        <mxCell id="proxy" value="&lt;b&gt;Proxy Node&lt;/b&gt;" style="swimlane;fontStyle=1;fontSize=16;fillColor=#f5f5f5;strokeColor=#555555;fontColor=#333333;startSize=45;" vertex="1" parent="1">
          <mxGeometry x="100" y="240" width="1454" height="370" as="geometry" />
        </mxCell>

        <!-- erawan-cluster API (child of proxy) -->
        <mxCell id="api" value="&lt;b&gt;erawan-cluster API&lt;/b&gt;&#xa;HTTP :8080&#xa;&#xa;&#x2022; Validates requests&#xa;&#x2022; Manages cluster jobs&#xa;&#x2022; Runs ansible-playbook via SSH&#xa;&#x2022; Serves metrics via HAProxy" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="proxy">
          <mxGeometry x="60" y="70" width="270" height="220" as="geometry" />
        </mxCell>

        <!-- Job State Store (child of proxy) -->
        <mxCell id="jobs" value="&lt;b&gt;Job State Store&lt;/b&gt;&#xa;/var/lib/erawan-cluster/cluster/jobs/&#xa;  mysql/&lt;jobID&gt;.json&#xa;  mysql/&lt;jobID&gt;.secret&#xa;  pgsql/&lt;jobID&gt;.json&#xa;  pgsql/&lt;jobID&gt;.secret" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="proxy">
          <mxGeometry x="60" y="300" width="270" height="40" as="geometry" />
        </mxCell>

        <!-- HAProxy (child of proxy) -->
        <mxCell id="haproxy" value="&lt;b&gt;HAProxy&lt;/b&gt;&#xa;:25041  MySQL frontend&#xa;:25042  PostgreSQL frontend&#xa;&#xa;&#x2022; TCP proxy, hot reload&#xa;&#x2022; roundrobin balancing&#xa;&#x2022; Patroni /leader health check&#xa;&#x2022; no restart on config change" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="proxy">
          <mxGeometry x="590" y="70" width="290" height="220" as="geometry" />
        </mxCell>

        <!-- Tenant Configs (child of proxy) -->
        <mxCell id="cfgs" value="&lt;b&gt;Tenant Configs&lt;/b&gt;&#xa;/var/lib/erawan-cluster&#xa;  /haproxy/tenants/&#xa;&#xa;  25041.cfg   ← MySQL cluster A&#xa;  25042.cfg   ← pgsql cluster B&#xa;  25043.cfg   ← MySQL cluster C" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=20;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="proxy">
          <mxGeometry x="1030" y="70" width="360" height="180" as="geometry" />
        </mxCell>

        <!-- Edges inside proxy -->
        <mxCell id="e-api-haproxy" value="write cfg + reload" style="endArrow=open;endFill=0;dashed=1;strokeColor=#555555;" edge="1" parent="proxy" source="api" target="haproxy">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-haproxy-cfg" value="reads" style="endArrow=open;endFill=0;dashed=1;strokeColor=#d6b656;" edge="1" parent="proxy" source="haproxy" target="cfgs">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-api-jobs" value="" style="endArrow=block;endFill=1;strokeColor=#b85450;" edge="1" parent="proxy" source="api" target="jobs">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ===== MYSQL CLUSTER ===== -->
        <mxCell id="mc" value="&lt;b&gt;MySQL Cluster&lt;/b&gt;  (InnoDB Cluster + Group Replication)" style="swimlane;fontStyle=1;fontSize=13;fillColor=#fff2cc;strokeColor=#d6b656;startSize=35;" vertex="1" parent="1">
          <mxGeometry x="80" y="720" width="720" height="280" as="geometry" />
        </mxCell>
        <mxCell id="mn1" value="&lt;b&gt;Node 1  [PRIMARY]&lt;/b&gt;&#xa;MySQL :3306&#xa;MySQL Router :6446&#xa;Group Replication" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="mc">
          <mxGeometry x="30" y="55" width="190" height="190" as="geometry" />
        </mxCell>
        <mxCell id="mn2" value="&lt;b&gt;Node 2  [SECONDARY]&lt;/b&gt;&#xa;MySQL :3306&#xa;MySQL Router :6446&#xa;Group Replication" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="mc">
          <mxGeometry x="265" y="55" width="190" height="190" as="geometry" />
        </mxCell>
        <mxCell id="mn3" value="&lt;b&gt;Node 3  [SECONDARY]&lt;/b&gt;&#xa;MySQL :3306&#xa;MySQL Router :6446&#xa;Group Replication" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="mc">
          <mxGeometry x="500" y="55" width="190" height="190" as="geometry" />
        </mxCell>
        <mxCell id="e-gr12" value="" style="endArrow=block;endFill=1;startArrow=block;startFill=1;strokeColor=#d6b656;" edge="1" parent="mc" source="mn1" target="mn2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-gr23" value="" style="endArrow=block;endFill=1;startArrow=block;startFill=1;strokeColor=#d6b656;" edge="1" parent="mc" source="mn2" target="mn3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ===== PGSQL CLUSTER ===== -->
        <mxCell id="pc" value="&lt;b&gt;PostgreSQL Cluster&lt;/b&gt;  (Patroni + etcd)" style="swimlane;fontStyle=1;fontSize=13;fillColor=#dae8fc;strokeColor=#6c8ebf;startSize=35;" vertex="1" parent="1">
          <mxGeometry x="854" y="720" width="720" height="280" as="geometry" />
        </mxCell>
        <mxCell id="pn1" value="&lt;b&gt;Node 1  [LEADER]&lt;/b&gt;&#xa;PostgreSQL :5432&#xa;Patroni :8008&#xa;etcd :2379 / :2380" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="pc">
          <mxGeometry x="25" y="55" width="200" height="190" as="geometry" />
        </mxCell>
        <mxCell id="pn2" value="&lt;b&gt;Node 2  [SYNC_STANDBY]&lt;/b&gt;&#xa;PostgreSQL :5432&#xa;Patroni :8008&#xa;etcd :2379 / :2380" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="pc">
          <mxGeometry x="260" y="55" width="200" height="190" as="geometry" />
        </mxCell>
        <mxCell id="pn3" value="&lt;b&gt;Node 3  [REPLICA]&lt;/b&gt;&#xa;PostgreSQL :5432&#xa;Patroni :8008&#xa;etcd :2379 / :2380" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="pc">
          <mxGeometry x="495" y="55" width="200" height="190" as="geometry" />
        </mxCell>
        <mxCell id="e-rep12" value="streaming" style="endArrow=block;endFill=1;strokeColor=#6c8ebf;" edge="1" parent="pc" source="pn1" target="pn2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-rep13" value="streaming" style="endArrow=block;endFill=1;strokeColor=#6c8ebf;" edge="1" parent="pc" source="pn1" target="pn3">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="125" y="260" />
              <mxPoint x="595" y="260" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- ===== TOP-LEVEL EDGES ===== -->
        <mxCell id="e-client-api" value="HTTP REST  X-API-Key" style="endArrow=block;endFill=1;strokeColor=#82b366;strokeWidth=2;fontSize=11;" edge="1" parent="1" source="client" target="api">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-client-haproxy" value="SQL  :25041 / :25042" style="endArrow=block;endFill=1;strokeColor=#d6b656;strokeWidth=2;fontSize=11;" edge="1" parent="1" source="client" target="haproxy">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-api-mc" value="SSH + ansible-playbook&#xa;deploy / add / remove member" style="endArrow=block;endFill=1;dashed=1;strokeColor=#82b366;strokeWidth=1;fontSize=11;" edge="1" parent="1" source="api" target="mc">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-api-pc" value="SSH + ansible-playbook&#xa;deploy / add / remove member" style="endArrow=block;endFill=1;dashed=1;strokeColor=#82b366;strokeWidth=1;fontSize=11;" edge="1" parent="1" source="api" target="pc">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="230" y="660" />
              <mxPoint x="1214" y="660" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e-haproxy-mc" value="TCP :3306" style="endArrow=block;endFill=1;strokeColor=#d6b656;strokeWidth=2;fontSize=11;" edge="1" parent="1" source="haproxy" target="mc">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-haproxy-pc" value="TCP :5432&#xa;health: GET /leader :8008" style="endArrow=block;endFill=1;strokeColor=#6c8ebf;strokeWidth=2;fontSize=11;" edge="1" parent="1" source="haproxy" target="pc">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Note -->
        <mxCell id="note" value="&lt;b&gt;Metric SQL rule:&lt;/b&gt;  API → PROXY_HOST:proxy_port → HAProxy → DB node  (never direct to DB node IPs)" style="text;html=1;strokeColor=#82b366;fillColor=#d5e8d4;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=12;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="377" y="1060" width="900" height="60" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
