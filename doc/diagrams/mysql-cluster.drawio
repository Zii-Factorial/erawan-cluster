<mxfile compressed="false">
  <diagram name="Architecture" id="mysql-arch">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="MySQL InnoDB Cluster — Architecture" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=22;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="327" y="20" width="1000" height="50" as="geometry" />
        </mxCell>

        <!-- Client -->
        <mxCell id="client" value="&lt;b&gt;Client Application&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="677" y="90" width="300" height="70" as="geometry" />
        </mxCell>

        <!-- HAProxy -->
        <mxCell id="haproxy" value="&lt;b&gt;HAProxy&lt;/b&gt;  :25041&#xa;&#xa;balance: roundrobin&#xa;backend: all 3 nodes :3306&#xa;option: tcp-check" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="627" y="240" width="400" height="120" as="geometry" />
        </mxCell>

        <!-- Node 1 (Primary) -->
        <mxCell id="n1-box" value="&lt;b&gt;Node 1  [PRIMARY]&lt;/b&gt;" style="swimlane;fontStyle=1;fontSize=13;fillColor=#ffe6cc;strokeColor=#d6b656;startSize=35;" vertex="1" parent="1">
          <mxGeometry x="100" y="460" width="340" height="340" as="geometry" />
        </mxCell>
        <mxCell id="n1-router" value="&lt;b&gt;MySQL Router&lt;/b&gt;&#xa;:6446  primary RW&#xa;:6447  secondary RO&#xa;&#xa;Routes to current primary&#xa;via metadata discovery" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="n1-box">
          <mxGeometry x="20" y="50" width="295" height="120" as="geometry" />
        </mxCell>
        <mxCell id="n1-mysql" value="&lt;b&gt;MySQL Server&lt;/b&gt;&#xa;:3306&#xa;&#xa;InnoDB engine&#xa;Group Replication&#xa;[ONLINE / PRIMARY]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="n1-box">
          <mxGeometry x="20" y="195" width="295" height="120" as="geometry" />
        </mxCell>

        <!-- Node 2 (Secondary) -->
        <mxCell id="n2-box" value="&lt;b&gt;Node 2  [SECONDARY]&lt;/b&gt;" style="swimlane;fontStyle=1;fontSize=13;fillColor=#fff2cc;strokeColor=#d6b656;startSize=35;" vertex="1" parent="1">
          <mxGeometry x="657" y="460" width="340" height="340" as="geometry" />
        </mxCell>
        <mxCell id="n2-router" value="&lt;b&gt;MySQL Router&lt;/b&gt;&#xa;:6446  primary RW&#xa;:6447  secondary RO&#xa;&#xa;Routes to current primary&#xa;via metadata discovery" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="n2-box">
          <mxGeometry x="20" y="50" width="295" height="120" as="geometry" />
        </mxCell>
        <mxCell id="n2-mysql" value="&lt;b&gt;MySQL Server&lt;/b&gt;&#xa;:3306&#xa;&#xa;InnoDB engine&#xa;Group Replication&#xa;[ONLINE / SECONDARY]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="n2-box">
          <mxGeometry x="20" y="195" width="295" height="120" as="geometry" />
        </mxCell>

        <!-- Node 3 (Secondary) -->
        <mxCell id="n3-box" value="&lt;b&gt;Node 3  [SECONDARY]&lt;/b&gt;" style="swimlane;fontStyle=1;fontSize=13;fillColor=#fff2cc;strokeColor=#d6b656;startSize=35;" vertex="1" parent="1">
          <mxGeometry x="1214" y="460" width="340" height="340" as="geometry" />
        </mxCell>
        <mxCell id="n3-router" value="&lt;b&gt;MySQL Router&lt;/b&gt;&#xa;:6446  primary RW&#xa;:6447  secondary RO&#xa;&#xa;Routes to current primary&#xa;via metadata discovery" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="n3-box">
          <mxGeometry x="20" y="50" width="295" height="120" as="geometry" />
        </mxCell>
        <mxCell id="n3-mysql" value="&lt;b&gt;MySQL Server&lt;/b&gt;&#xa;:3306&#xa;&#xa;InnoDB engine&#xa;Group Replication&#xa;[ONLINE / SECONDARY]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="n3-box">
          <mxGeometry x="20" y="195" width="295" height="120" as="geometry" />
        </mxCell>

        <!-- InnoDB Cluster GR layer -->
        <mxCell id="gr" value="InnoDB Cluster / Group Replication&#xa;Built-in consensus — automatic failover — multi-primary capable&#xa;auto_rejoin_tries=3   exit_state_action=READ_ONLY   start_on_boot=ON" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#555555;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="860" width="1454" height="80" as="geometry" />
        </mxCell>

        <!-- Edges -->
        <mxCell id="e-client-haproxy" value="SQL connections" style="endArrow=block;endFill=1;strokeColor=#d6b656;strokeWidth=2;fontSize=11;" edge="1" parent="1" source="client" target="haproxy">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-haproxy-n1" value=":3306" style="endArrow=block;endFill=1;strokeColor=#d6b656;strokeWidth=2;fontSize=11;" edge="1" parent="1" source="haproxy" target="n1-box">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-haproxy-n2" value=":3306" style="endArrow=block;endFill=1;strokeColor=#d6b656;strokeWidth=2;fontSize=11;" edge="1" parent="1" source="haproxy" target="n2-box">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-haproxy-n3" value=":3306" style="endArrow=block;endFill=1;strokeColor=#d6b656;strokeWidth=2;fontSize=11;" edge="1" parent="1" source="haproxy" target="n3-box">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- GR connections -->
        <mxCell id="e-gr-n1" value="" style="endArrow=block;endFill=1;startArrow=block;startFill=1;strokeColor=#555555;" edge="1" parent="1" source="n1-box" target="gr">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-gr-n2" value="" style="endArrow=block;endFill=1;startArrow=block;startFill=1;strokeColor=#555555;" edge="1" parent="1" source="n2-box" target="gr">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-gr-n3" value="" style="endArrow=block;endFill=1;startArrow=block;startFill=1;strokeColor=#555555;" edge="1" parent="1" source="n3-box" target="gr">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- MySQL Router reads metadata note -->
        <mxCell id="note-router" value="MySQL Router on each node reads InnoDB Cluster metadata to discover which node is the current primary. Clients connect to Router :6446 for read-write or HAProxy :25041 for SQL proxy." style="text;html=1;strokeColor=#d6b656;fillColor=#fff2cc;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="100" y="990" width="1454" height="60" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

  <diagram name="Failover Flow" id="mysql-failover">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="MySQL InnoDB Cluster — Failover Flow" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=22;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="327" y="20" width="1000" height="50" as="geometry" />
        </mxCell>

        <!-- Before state -->
        <mxCell id="before" value="&lt;b&gt;BEFORE FAILOVER&lt;/b&gt;" style="swimlane;fontStyle=1;fontSize=14;fillColor=#d5e8d4;strokeColor=#82b366;startSize=35;" vertex="1" parent="1">
          <mxGeometry x="80" y="90" width="720" height="160" as="geometry" />
        </mxCell>
        <mxCell id="b-n1" value="Node 1  [PRIMARY ✓]&#xa;MySQL :3306  ONLINE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="before">
          <mxGeometry x="20" y="50" width="200" height="80" as="geometry" />
        </mxCell>
        <mxCell id="b-n2" value="Node 2  [SECONDARY]&#xa;MySQL :3306  ONLINE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="before">
          <mxGeometry x="260" y="50" width="200" height="80" as="geometry" />
        </mxCell>
        <mxCell id="b-n3" value="Node 3  [SECONDARY]&#xa;MySQL :3306  ONLINE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="before">
          <mxGeometry x="500" y="50" width="200" height="80" as="geometry" />
        </mxCell>

        <!-- After state -->
        <mxCell id="after" value="&lt;b&gt;AFTER FAILOVER&lt;/b&gt;" style="swimlane;fontStyle=1;fontSize=14;fillColor=#dae8fc;strokeColor=#6c8ebf;startSize=35;" vertex="1" parent="1">
          <mxGeometry x="860" y="90" width="720" height="160" as="geometry" />
        </mxCell>
        <mxCell id="a-n1" value="Node 1  [SECONDARY / recovering]&#xa;MySQL :3306  rejoining" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="after">
          <mxGeometry x="20" y="50" width="220" height="80" as="geometry" />
        </mxCell>
        <mxCell id="a-n2" value="Node 2  [PRIMARY ✓]&#xa;MySQL :3306  ONLINE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="after">
          <mxGeometry x="260" y="50" width="200" height="80" as="geometry" />
        </mxCell>
        <mxCell id="a-n3" value="Node 3  [SECONDARY]&#xa;MySQL :3306  ONLINE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="after">
          <mxGeometry x="500" y="50" width="200" height="80" as="geometry" />
        </mxCell>

        <!-- Step 1 -->
        <mxCell id="s1" value="&lt;b&gt;① Node 1 (Primary) dies&lt;/b&gt;&#xa;&#xa;Crash / network partition / process kill.&#xa;Node 1 stops responding to Group Replication heartbeats." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="527" y="330" width="600" height="100" as="geometry" />
        </mxCell>

        <!-- Step 2 -->
        <mxCell id="s2" value="&lt;b&gt;② GR detects member loss&lt;/b&gt;&#xa;&#xa;Remaining members (Node 2, 3) detect unreachable_majority_timeout.&#xa;Node 1 is expelled. GR starts election." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="527" y="470" width="600" height="100" as="geometry" />
        </mxCell>

        <!-- Step 3 -->
        <mxCell id="s3" value="&lt;b&gt;③ Majority vote — Node 2 elected PRIMARY&lt;/b&gt;&#xa;&#xa;Node 2 and Node 3 form a majority (2 of 2 remaining).&#xa;Node 2 is promoted to PRIMARY. Node 3 stays SECONDARY." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="527" y="610" width="600" height="100" as="geometry" />
        </mxCell>

        <!-- Step 4 -->
        <mxCell id="s4" value="&lt;b&gt;④ MySQL Router refreshes cluster metadata&lt;/b&gt;&#xa;&#xa;Router on all nodes polls InnoDB Cluster metadata.&#xa;New primary (Node 2) is discovered. Routing tables updated." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="527" y="750" width="600" height="100" as="geometry" />
        </mxCell>

        <!-- Step 5 -->
        <mxCell id="s5" value="&lt;b&gt;⑤ New connections routed to Node 2&lt;/b&gt;&#xa;&#xa;HAProxy: all 3 backends still in rotation.&#xa;MySQL Router :6446 now connects to Node 2:3306.&#xa;Existing connections on Node 1 are dropped and must reconnect." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="527" y="890" width="600" height="120" as="geometry" />
        </mxCell>

        <!-- Step 6 -->
        <mxCell id="s6" value="&lt;b&gt;⑥ Node 1 recovers and rejoins as SECONDARY&lt;/b&gt;&#xa;&#xa;When Node 1 comes back, auto_rejoin_tries=3 causes it to&#xa;attempt Group Replication rejoin automatically.&#xa;Recovery method: auto (incremental preferred, clone fallback)." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="527" y="1050" width="600" height="100" as="geometry" />
        </mxCell>

        <!-- Arrows between steps -->
        <mxCell id="e-s1-s2" value="" style="endArrow=block;endFill=1;strokeColor=#555555;strokeWidth=2;" edge="1" parent="1" source="s1" target="s2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-s2-s3" value="" style="endArrow=block;endFill=1;strokeColor=#555555;strokeWidth=2;" edge="1" parent="1" source="s2" target="s3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-s3-s4" value="" style="endArrow=block;endFill=1;strokeColor=#555555;strokeWidth=2;" edge="1" parent="1" source="s3" target="s4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-s4-s5" value="" style="endArrow=block;endFill=1;strokeColor=#555555;strokeWidth=2;" edge="1" parent="1" source="s4" target="s5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-s5-s6" value="later" style="endArrow=block;endFill=1;strokeColor=#555555;strokeWidth=2;dashed=1;" edge="1" parent="1" source="s5" target="s6">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Before/After arrows -->
        <mxCell id="e-before-s1" value="" style="endArrow=block;endFill=1;strokeColor=#b85450;strokeWidth=2;" edge="1" parent="1" source="before" target="s1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-s5-after" value="" style="endArrow=block;endFill=1;strokeColor=#6c8ebf;strokeWidth=2;" edge="1" parent="1" source="s5" target="after">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Timing note -->
        <mxCell id="note-timing" value="Typical failover time: 20–60 seconds (GR detection + election + Router refresh)" style="text;html=1;strokeColor=#555555;fillColor=#f5f5f5;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=12;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="377" y="1100" width="900" height="50" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
