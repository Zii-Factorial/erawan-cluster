<mxfile host="app.diagrams.net" type="device">
  <diagram name="k8s-ha-architecture" id="k8s-ha-1">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1300" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="erawan-cluster — HA Proxy Node on CloudStack Kubernetes (CKS)" style="text;html=1;fontSize=16;fontStyle=1;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="900" height="30" as="geometry" />
        </mxCell>

        <!-- Clients -->
        <mxCell id="sqlc" value="SQL Clients&#10;(apps)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="40" y="150" width="150" height="60" as="geometry" />
        </mxCell>
        <mxCell id="admin" value="Admin / API&#10;clients" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="40" y="250" width="150" height="60" as="geometry" />
        </mxCell>

        <!-- CloudStack LB -->
        <mxCell id="lb" value="CloudStack L4 LB (VIP)&#10;&#10;:25041..N  SQL&#10;:8080       API&#10;&#10;health-checked, balanced" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="250" y="160" width="170" height="170" as="geometry" />
        </mxCell>

        <!-- k8s cluster boundary -->
        <mxCell id="k8s" value="CKS cluster   ·   namespace: erawan   ·   StatefulSet (anti-affinity, PDB, HPA)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#326ce5;dashed=1;verticalAlign=top;fontStyle=1;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="470" y="80" width="470" height="380" as="geometry" />
        </mxCell>

        <!-- Pods -->
        <mxCell id="p1" value="Proxy Pod 1   [ LEADER ]&#10;Go API + Reconciler  ·  HAProxy :25041..N&#10;(runs Ansible jobs via lease)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="495" y="120" width="420" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p2" value="Proxy Pod 2&#10;Go API + Reconciler  ·  HAProxy :25041..N" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="495" y="215" width="420" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p3" value="Proxy Pod 3   (scale out →)&#10;Go API + Reconciler  ·  HAProxy :25041..N" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="495" y="300" width="420" height="70" as="geometry" />
        </mxCell>

        <!-- Control DB -->
        <mxCell id="cdb" value="Shared Control DB&#10;(Patroni Postgres, HA)&#10;&#10;tenants · jobs&#10;job_secrets · leases" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="990" y="150" width="180" height="150" as="geometry" />
        </mxCell>

        <!-- DB VMs -->
        <mxCell id="dbvms" value="CloudStack DB node VMs (tenant clusters)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#666666;dashed=1;verticalAlign=top;fontStyle=1;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="250" y="510" width="690" height="130" as="geometry" />
        </mxCell>
        <mxCell id="dba" value="Cluster A&#10;MySQL (Router)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="280" y="550" width="180" height="70" as="geometry" />
        </mxCell>
        <mxCell id="dbb" value="Cluster B&#10;PostgreSQL (Patroni)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="490" y="550" width="180" height="70" as="geometry" />
        </mxCell>
        <mxCell id="dbc" value="Cluster C&#10;MySQL (Router)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="700" y="550" width="180" height="70" as="geometry" />
        </mxCell>

        <!-- Legend -->
        <mxCell id="legend" value="Legend&#10;━━  SQL data plane (client → DB)&#10;┈┈  control plane (reconcile / jobs)&#10;┈┈  Ansible SSH (leader only)" style="text;html=1;align=left;verticalAlign=top;fillColor=#f5f5f5;strokeColor=#999999;spacingLeft=8;spacingTop=6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="990" y="330" width="180" height="100" as="geometry" />
        </mxCell>

        <!-- Edges: SQL data plane (blue solid) -->
        <mxCell id="e_sqlc_lb" value="SQL TCP" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#1f6feb;strokeWidth=2;fontColor=#1f6feb;" edge="1" parent="1" source="sqlc" target="lb">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_lb_p1" value="balanced" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#1f6feb;strokeWidth=2;fontColor=#1f6feb;" edge="1" parent="1" source="lb" target="p1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_lb_p2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#1f6feb;strokeWidth=2;" edge="1" parent="1" source="lb" target="p2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_lb_p3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#1f6feb;strokeWidth=2;" edge="1" parent="1" source="lb" target="p3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_p2_db" value="SQL → current primary" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#1f6feb;strokeWidth=2;fontColor=#1f6feb;exitX=0;exitY=0.5;entryX=0.5;entryY=0;" edge="1" parent="1" source="p2" target="dbvms">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_p3_db" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#1f6feb;strokeWidth=2;" edge="1" parent="1" source="p3" target="dbvms">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Edges: Admin → LB → API (gray) -->
        <mxCell id="e_admin_lb" value="API HTTP" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#9673a6;strokeWidth=2;fontColor=#9673a6;" edge="1" parent="1" source="admin" target="lb">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Edges: control plane (dashed gray) pods <-> control DB -->
        <mxCell id="e_p1_cdb" value="reconcile + jobs/secrets" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;strokeColor=#666666;startArrow=classic;startFill=1;" edge="1" parent="1" source="p1" target="cdb">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_p2_cdb" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;strokeColor=#666666;startArrow=classic;startFill=1;" edge="1" parent="1" source="p2" target="cdb">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_p3_cdb" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;strokeColor=#666666;startArrow=classic;startFill=1;" edge="1" parent="1" source="p3" target="cdb">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Edge: Ansible from leader (dashed orange) -->
        <mxCell id="e_p1_db" value="Ansible / SSH (leader only)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;strokeColor=#d79b00;strokeWidth=2;fontColor=#d79b00;exitX=0;exitY=0.5;entryX=0.5;entryY=0;" edge="1" parent="1" source="p1" target="dbvms">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
