<mxfile compressed="false">
  <diagram name="Architecture" id="pgsql-arch">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="PostgreSQL HA Cluster — Architecture (Patroni + etcd)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=22;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="227" y="20" width="1200" height="50" as="geometry" />
        </mxCell>

        <!-- Client -->
        <mxCell id="client" value="&lt;b&gt;Client Application&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="677" y="90" width="300" height="70" as="geometry" />
        </mxCell>

        <!-- HAProxy -->
        <mxCell id="haproxy" value="&lt;b&gt;HAProxy&lt;/b&gt;  :25042&#xa;&#xa;Health check: GET /leader on :8008&#xa;200 OK → leader (receives writes)&#xa;503 → standby (excluded)&#xa;&#xa;Only ONE node active at a time." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;fontSize=12;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="577" y="240" width="500" height="150" as="geometry" />
        </mxCell>

        <!-- Node 1 -->
        <mxCell id="n1" value="&lt;b&gt;Node 1  [LEADER]&lt;/b&gt;" style="swimlane;fontStyle=1;fontSize=13;fillColor=#d5e8d4;strokeColor=#82b366;startSize=35;" vertex="1" parent="1">
          <mxGeometry x="80" y="500" width="340" height="380" as="geometry" />
        </mxCell>
        <mxCell id="n1-patroni" value="&lt;b&gt;Patroni&lt;/b&gt;  :8008&#xa;&#xa;/leader → 200 OK&#xa;Holds etcd DCS lock&#xa;Manages PostgreSQL process" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="n1">
          <mxGeometry x="20" y="50" width="295" height="110" as="geometry" />
        </mxCell>
        <mxCell id="n1-pg" value="&lt;b&gt;PostgreSQL&lt;/b&gt;  :5432&#xa;&#xa;Read + Write&#xa;primary mode&#xa;WAL sender active" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="n1">
          <mxGeometry x="20" y="185" width="295" height="100" as="geometry" />
        </mxCell>
        <mxCell id="n1-etcd" value="&lt;b&gt;etcd&lt;/b&gt;  :2379 / :2380&#xa;&#xa;Consensus member&#xa;Stores Patroni leader lock" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="n1">
          <mxGeometry x="20" y="310" width="295" height="50" as="geometry" />
        </mxCell>

        <!-- Node 2 -->
        <mxCell id="n2" value="&lt;b&gt;Node 2  [SYNC_STANDBY]&lt;/b&gt;" style="swimlane;fontStyle=1;fontSize=13;fillColor=#dae8fc;strokeColor=#6c8ebf;startSize=35;" vertex="1" parent="1">
          <mxGeometry x="657" y="500" width="340" height="380" as="geometry" />
        </mxCell>
        <mxCell id="n2-patroni" value="&lt;b&gt;Patroni&lt;/b&gt;  :8008&#xa;&#xa;/leader → 503&#xa;/replica → 200 OK&#xa;Monitors leader via etcd lock" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="n2">
          <mxGeometry x="20" y="50" width="295" height="110" as="geometry" />
        </mxCell>
        <mxCell id="n2-pg" value="&lt;b&gt;PostgreSQL&lt;/b&gt;  :5432&#xa;&#xa;Read-only (hot_standby=on)&#xa;streaming replication WAL receiver&#xa;Sync: ack required for commit" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="n2">
          <mxGeometry x="20" y="185" width="295" height="100" as="geometry" />
        </mxCell>
        <mxCell id="n2-etcd" value="&lt;b&gt;etcd&lt;/b&gt;  :2379 / :2380&#xa;&#xa;Consensus member&#xa;Votes for leader election" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="n2">
          <mxGeometry x="20" y="310" width="295" height="50" as="geometry" />
        </mxCell>

        <!-- Node 3 -->
        <mxCell id="n3" value="&lt;b&gt;Node 3  [REPLICA]&lt;/b&gt;" style="swimlane;fontStyle=1;fontSize=13;fillColor=#dae8fc;strokeColor=#6c8ebf;startSize=35;" vertex="1" parent="1">
          <mxGeometry x="1234" y="500" width="340" height="380" as="geometry" />
        </mxCell>
        <mxCell id="n3-patroni" value="&lt;b&gt;Patroni&lt;/b&gt;  :8008&#xa;&#xa;/leader → 503&#xa;/replica → 200 OK&#xa;Monitors leader via etcd lock" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="n3">
          <mxGeometry x="20" y="50" width="295" height="110" as="geometry" />
        </mxCell>
        <mxCell id="n3-pg" value="&lt;b&gt;PostgreSQL&lt;/b&gt;  :5432&#xa;&#xa;Read-only (hot_standby=on)&#xa;streaming replication WAL receiver&#xa;Async: does not block commits" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="n3">
          <mxGeometry x="20" y="185" width="295" height="100" as="geometry" />
        </mxCell>
        <mxCell id="n3-etcd" value="&lt;b&gt;etcd&lt;/b&gt;  :2379 / :2380&#xa;&#xa;Consensus member&#xa;Votes for leader election" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="n3">
          <mxGeometry x="20" y="310" width="295" height="50" as="geometry" />
        </mxCell>

        <!-- etcd DCS layer -->
        <mxCell id="etcd-dcs" value="etcd DCS Cluster  (3-node consensus, majority quorum)&#xa;Stores: Patroni leader lock, cluster config, member state, sync_standby election" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#555555;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="950" width="1494" height="80" as="geometry" />
        </mxCell>

        <!-- Edges -->
        <mxCell id="e-client-haproxy" value="SQL writes" style="endArrow=block;endFill=1;strokeColor=#d6b656;strokeWidth=2;fontSize=11;" edge="1" parent="1" source="client" target="haproxy">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-haproxy-n1" value="health: /leader 200&#xa;:5432 (SQL)" style="endArrow=block;endFill=1;strokeColor=#82b366;strokeWidth=2;fontSize=11;" edge="1" parent="1" source="haproxy" target="n1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-haproxy-n2" value="health: /leader 503&#xa;(excluded)" style="endArrow=block;endFill=1;strokeColor=#b85450;strokeWidth=1;dashed=1;fontSize=11;" edge="1" parent="1" source="haproxy" target="n2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-haproxy-n3" value="health: /leader 503&#xa;(excluded)" style="endArrow=block;endFill=1;strokeColor=#b85450;strokeWidth=1;dashed=1;fontSize=11;" edge="1" parent="1" source="haproxy" target="n3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Streaming replication -->
        <mxCell id="e-rep12" value="WAL streaming (sync)" style="endArrow=block;endFill=1;strokeColor=#6c8ebf;strokeWidth=2;fontSize=11;" edge="1" parent="1" source="n1" target="n2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-rep13" value="WAL streaming (async)" style="endArrow=block;endFill=1;strokeColor=#6c8ebf;strokeWidth=1;dashed=1;fontSize=11;" edge="1" parent="1" source="n1" target="n3">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="250" y="920" />
              <mxPoint x="1404" y="920" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- etcd connections -->
        <mxCell id="e-n1-etcd" value="" style="endArrow=block;endFill=1;startArrow=block;startFill=1;strokeColor=#555555;" edge="1" parent="1" source="n1" target="etcd-dcs">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-n2-etcd" value="" style="endArrow=block;endFill=1;startArrow=block;startFill=1;strokeColor=#555555;" edge="1" parent="1" source="n2" target="etcd-dcs">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-n3-etcd" value="" style="endArrow=block;endFill=1;startArrow=block;startFill=1;strokeColor=#555555;" edge="1" parent="1" source="n3" target="etcd-dcs">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Legend -->
        <mxCell id="legend" value="Legend:  — solid line = active path  — dashed line = excluded (503) / async" style="text;html=1;strokeColor=#555555;fillColor=#f5f5f5;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=11;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="80" y="1070" width="1494" height="50" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

  <diagram name="Failover and Add Member" id="pgsql-flows">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1654" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="PostgreSQL HA Cluster — Failover Flow &amp; Add Member Flow" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=22;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="127" y="20" width="1400" height="50" as="geometry" />
        </mxCell>

        <!-- ===== FAILOVER FLOW (LEFT) ===== -->
        <mxCell id="fo-title" value="FAILOVER FLOW" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=16;fontStyle=1;fontColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="80" y="80" width="640" height="40" as="geometry" />
        </mxCell>

        <!-- Before state -->
        <mxCell id="fo-before" value="&lt;b&gt;BEFORE&lt;/b&gt;&#xa;Node 1 = LEADER  |  Node 2 = sync_standby  |  Node 3 = replica" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="140" width="640" height="70" as="geometry" />
        </mxCell>

        <!-- Failover steps -->
        <mxCell id="fo-s1" value="&lt;b&gt;① Node 1 (Leader) dies&lt;/b&gt;&#xa;&#xa;Process crash, OOM, or network partition.&#xa;Node 1 stops renewing the Patroni etcd lock (TTL=30s).&#xa;Node 1 PostgreSQL is no longer accepting connections." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="250" width="640" height="110" as="geometry" />
        </mxCell>

        <mxCell id="fo-s2" value="&lt;b&gt;② Patroni on Node 2 detects leader loss&lt;/b&gt;&#xa;&#xa;Patroni loop (loop_wait=10s) polls etcd.&#xa;etcd lock has expired (TTL elapsed).&#xa;Node 2 is sync_standby → eligible to promote." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="400" width="640" height="110" as="geometry" />
        </mxCell>

        <mxCell id="fo-s3" value="&lt;b&gt;③ Node 2 acquires etcd lock → becomes leader&lt;/b&gt;&#xa;&#xa;Patroni writes new leader key to etcd.&#xa;Node 2 PostgreSQL is promoted: pg_ctl promote&#xa;Node 2 /leader now returns HTTP 200." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="550" width="640" height="110" as="geometry" />
        </mxCell>

        <mxCell id="fo-s4" value="&lt;b&gt;④ HAProxy reroutes in ≤10s&lt;/b&gt;&#xa;&#xa;HAProxy health check fires.&#xa;Node 1: /leader → no response or 503.&#xa;Node 2: /leader → 200 OK.&#xa;All new SQL connections route to Node 2:5432." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="700" width="640" height="130" as="geometry" />
        </mxCell>

        <mxCell id="fo-s5" value="&lt;b&gt;⑤ Node 3 elects as new sync_standby&lt;/b&gt;&#xa;&#xa;Node 3 (replica) reads new leader from etcd.&#xa;Patroni on Node 2 (new leader) elects Node 3 as sync_standby.&#xa;pg_rewind runs if Node 3 timeline diverged." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="870" width="640" height="130" as="geometry" />
        </mxCell>

        <mxCell id="fo-s6" value="&lt;b&gt;⑥ Node 1 recovers (rejoins as replica)&lt;/b&gt;&#xa;&#xa;When Node 1 comes back online, Patroni runs pg_rewind&#xa;to reconcile its WAL timeline against Node 2 (new leader).&#xa;Node 1 starts streaming replication from Node 2.&#xa;Cluster: Node 2=leader, Node 3=sync_standby, Node 1=replica." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="1040" width="640" height="140" as="geometry" />
        </mxCell>

        <!-- After state -->
        <mxCell id="fo-after" value="&lt;b&gt;AFTER&lt;/b&gt;&#xa;Node 2 = LEADER  |  Node 3 = sync_standby  |  Node 1 = replica" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="1220" width="640" height="70" as="geometry" />
        </mxCell>

        <!-- Failover timing note -->
        <mxCell id="fo-timing" value="Typical failover time: 10–40 seconds (etcd TTL + Patroni loop + HAProxy check)" style="text;html=1;strokeColor=#b85450;fillColor=#f8cecc;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=11;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="80" y="1320" width="640" height="50" as="geometry" />
        </mxCell>

        <!-- Failover arrows -->
        <mxCell id="e-fo-b-s1" value="" style="endArrow=block;endFill=1;strokeColor=#555555;strokeWidth=2;" edge="1" parent="1" source="fo-before" target="fo-s1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-fo-s1-s2" value="" style="endArrow=block;endFill=1;strokeColor=#555555;strokeWidth=2;" edge="1" parent="1" source="fo-s1" target="fo-s2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-fo-s2-s3" value="" style="endArrow=block;endFill=1;strokeColor=#555555;strokeWidth=2;" edge="1" parent="1" source="fo-s2" target="fo-s3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-fo-s3-s4" value="" style="endArrow=block;endFill=1;strokeColor=#555555;strokeWidth=2;" edge="1" parent="1" source="fo-s3" target="fo-s4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-fo-s4-s5" value="" style="endArrow=block;endFill=1;strokeColor=#555555;strokeWidth=2;" edge="1" parent="1" source="fo-s4" target="fo-s5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-fo-s5-s6" value="later" style="endArrow=block;endFill=1;strokeColor=#555555;strokeWidth=2;dashed=1;" edge="1" parent="1" source="fo-s5" target="fo-s6">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-fo-s6-after" value="" style="endArrow=block;endFill=1;strokeColor=#555555;strokeWidth=2;" edge="1" parent="1" source="fo-s6" target="fo-after">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ===== ADD MEMBER FLOW (RIGHT) ===== -->
        <mxCell id="am-title" value="ADD MEMBER FLOW" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=16;fontStyle=1;fontColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="934" y="80" width="640" height="40" as="geometry" />
        </mxCell>

        <!-- API call -->
        <mxCell id="am-s0" value="&lt;b&gt;POST /cluster/pgsql/members&lt;/b&gt;&#xa;{ job_id, member_ips: [&quot;10.0.0.4&quot;] }&#xa;→ 202 Accepted  { job_id }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="934" y="140" width="640" height="90" as="geometry" />
        </mxCell>

        <mxCell id="am-s1" value="&lt;b&gt;① Register new node as etcd learner&lt;/b&gt;&#xa;&#xa;etcdctl member add node4 --peer-urls=http://10.0.0.4:2380&#xa;New node is a non-voting learner first (safe, no quorum impact)." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="934" y="270" width="640" height="110" as="geometry" />
        </mxCell>

        <mxCell id="am-s2" value="&lt;b&gt;② Configure etcd on the new node&lt;/b&gt;&#xa;&#xa;Write /etc/etcd/etcd.conf with INITIAL_CLUSTER_STATE=existing.&#xa;Include all existing members in initial-cluster.&#xa;Start etcd.service — node joins existing cluster." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="934" y="420" width="640" height="120" as="geometry" />
        </mxCell>

        <mxCell id="am-s3" value="&lt;b&gt;③ Write patroni.yml on new node&lt;/b&gt;&#xa;&#xa;Write /etc/patroni/patroni.yml with:&#xa;  - scope, name, etcd hosts (all nodes)&#xa;  - bootstrap.dcs settings inherited from DCS&#xa;Start patroni.service." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="934" y="580" width="640" height="130" as="geometry" />
        </mxCell>

        <mxCell id="am-s4" value="&lt;b&gt;④ Patroni clones data via pg_basebackup&lt;/b&gt;&#xa;&#xa;New node detects no local data directory.&#xa;Patroni runs pg_basebackup from the current leader.&#xa;This copies the full data directory (may take time on large DBs)." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="934" y="750" width="640" height="130" as="geometry" />
        </mxCell>

        <mxCell id="am-s5" value="&lt;b&gt;⑤ Streaming replication starts&lt;/b&gt;&#xa;&#xa;New node connects to leader as a WAL receiver.&#xa;Replication lag drops as WAL catches up.&#xa;Patroni /replica returns 200 OK when in sync." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="934" y="920" width="640" height="110" as="geometry" />
        </mxCell>

        <mxCell id="am-s6" value="&lt;b&gt;⑥ Cluster verification&lt;/b&gt;&#xa;&#xa;Verify new node /replica returns 200 OK.&#xa;pg_stat_replication shows new member.&#xa;If no sync_standby exists, Patroni may elect new node as sync_standby." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="934" y="1070" width="640" height="130" as="geometry" />
        </mxCell>

        <mxCell id="am-done" value="&lt;b&gt;Member added successfully&lt;/b&gt;&#xa;Cluster now has N+1 nodes." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="934" y="1240" width="640" height="60" as="geometry" />
        </mxCell>

        <!-- Add member arrows -->
        <mxCell id="e-am-s0-s1" value="" style="endArrow=block;endFill=1;strokeColor=#555555;strokeWidth=2;" edge="1" parent="1" source="am-s0" target="am-s1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-am-s1-s2" value="" style="endArrow=block;endFill=1;strokeColor=#555555;strokeWidth=2;" edge="1" parent="1" source="am-s1" target="am-s2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-am-s2-s3" value="" style="endArrow=block;endFill=1;strokeColor=#555555;strokeWidth=2;" edge="1" parent="1" source="am-s2" target="am-s3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-am-s3-s4" value="" style="endArrow=block;endFill=1;strokeColor=#555555;strokeWidth=2;" edge="1" parent="1" source="am-s3" target="am-s4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-am-s4-s5" value="" style="endArrow=block;endFill=1;strokeColor=#555555;strokeWidth=2;" edge="1" parent="1" source="am-s4" target="am-s5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-am-s5-s6" value="" style="endArrow=block;endFill=1;strokeColor=#555555;strokeWidth=2;" edge="1" parent="1" source="am-s5" target="am-s6">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-am-s6-done" value="" style="endArrow=block;endFill=1;strokeColor=#82b366;strokeWidth=2;" edge="1" parent="1" source="am-s6" target="am-done">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Separator -->
        <mxCell id="sep" value="" style="line;strokeWidth=2;strokeColor=#CCCCCC;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="827" y="80" width="10" height="1300" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
