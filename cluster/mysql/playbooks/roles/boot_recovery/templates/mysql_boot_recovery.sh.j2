#!/bin/bash
# Auto-reboots InnoDB Cluster after a complete outage (all nodes down together).
# Installed on every node. Staggered delay (30 / 60 / 90 s) prevents all nodes
# racing to bootstrap simultaneously. The first node to run wins; others see GR
# already ONLINE and exit. The existing GR watchdog rejoins remaining secondaries.
set -uo pipefail

CONF=/etc/erawan-cluster/mysql-recovery.json
[ -f "$CONF" ] || { logger -t erawan-boot-recovery "no config found, skipping"; exit 0; }

# Wait up to 120 s for local MySQL to accept connections
_ready=0
for i in $(seq 1 60); do
  if mysql -uroot -e "SELECT 1" >/dev/null 2>&1; then _ready=1; break; fi
  sleep 2
done
if [[ "$_ready" -eq 0 ]]; then
  logger -t erawan-boot-recovery "MySQL not ready after 120s, skipping"
  exit 0
fi

logger -t erawan-boot-recovery "sleeping ${BOOT_RECOVERY_DELAY_SECONDS:-30}s before recovery check"
sleep "${BOOT_RECOVERY_DELAY_SECONDS:-30}"

# Exit early if ANY cluster member is already ONLINE (another node recovered first)
ONLINE_COUNT=$(mysql -uroot -Nse \
  "SELECT COUNT(*) FROM performance_schema.replication_group_members \
   WHERE member_state = 'ONLINE'" 2>/dev/null || echo "0")
if [[ "${ONLINE_COUNT}" -gt 0 ]]; then
  logger -t erawan-boot-recovery "cluster already has ${ONLINE_COUNT} ONLINE member(s), skipping"
  exit 0
fi

logger -t erawan-boot-recovery "no ONLINE members found — attempting reboot_cluster_from_complete_outage"

_tmp=""
trap 'rm -f "$_tmp"' EXIT
_tmp=$(mktemp /tmp/erawan-boot-XXXXXX.py)
cat >"$_tmp" <<'PY'
import json

shell.options["useWizards"] = False

with open("/etc/erawan-cluster/mysql-recovery.json") as f:
    cfg = json.load(f)

def connect_local():
    shell.connect({
        "user":     cfg["admin_user"],
        "password": cfg["admin_pass"],
        "host":     "127.0.0.1",
        "port":     cfg["mysql_port"],
        "scheme":   "mysql",
    })

# Get this node's GR identity (the IP stored in replication_group_members.member_host).
connect_local()
this_ip = shell.get_session().run_sql("SELECT @@report_host").fetch_one()[0]
print(f"this_node_ip: {this_ip}")

def rejoin_this_node():
    """Connect to each peer node and call cluster.rejoinInstance for this node."""
    for seed_ip in cfg.get("node_ips", []):
        if seed_ip == this_ip:
            continue
        try:
            shell.connect({
                "user":     cfg["admin_user"],
                "password": cfg["admin_pass"],
                "host":     seed_ip,
                "port":     cfg["mysql_port"],
                "scheme":   "mysql",
            })
            cluster = dba.get_cluster(cfg["cluster_name"])
            cluster.rejoin_instance(
                f"{cfg['admin_user']}@{this_ip}:{cfg['mysql_port']}",
                {"password": cfg["admin_pass"]},
            )
            print(f"rejoined cluster via {seed_ip}")
            return True
        except Exception as e:
            msg = str(e).lower()
            if "already a member" in msg:
                print(f"already a cluster member")
                return True
            print(f"rejoin via {seed_ip}: {e}")
    return False

is_already_active = False
try:
    connect_local()
    # mysqlsh picks the node with the highest GTID as primary, preserving the
    # most recent transactions.
    dba.reboot_cluster_from_complete_outage(cfg["cluster_name"])
    print("cluster rebooted (quorum-safe)")
except Exception as first_err:
    first_msg = str(first_err).lower()
    if any(t in first_msg for t in ("already active", "online", "is running", "cluster is active")):
        is_already_active = True
    else:
        # Force reboot from this node (e.g. not all members reachable yet).
        try:
            connect_local()
            dba.reboot_cluster_from_complete_outage(cfg["cluster_name"], {"force": True})
            print("cluster rebooted (forced)")
        except Exception as force_err:
            force_msg = str(force_err).lower()
            if any(t in force_msg for t in ("already active", "online", "is running", "cluster is active")):
                is_already_active = True
            else:
                raise

if is_already_active:
    print("cluster is already active — attempting rejoin of this node")
    if not rejoin_this_node():
        print("all rejoin attempts failed — GR watchdog will retry within 60s")
PY

if mysqlsh --no-wizard --py --file "$_tmp"; then
  logger -t erawan-boot-recovery "boot recovery succeeded"
else
  rc=$?
  # A benign "rejoin failed, watchdog will retry" outcome never raises in the
  # Python block above, so mysqlsh still exits 0 for it — only a genuine
  # unhandled exception (e.g. reboot_cluster_from_complete_outage itself
  # failing) lands here. Propagate it so the caller (systemd, then Ansible,
  # then the job status) sees the real failure instead of a false success.
  logger -t erawan-boot-recovery "boot recovery failed (mysqlsh exit $rc) — see this log for the mysqlsh traceback"
  exit "$rc"
fi
