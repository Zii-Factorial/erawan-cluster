[Unit]
Description=MySQL Router for {{ cluster_name }}
After=network.target mysql.service
Wants=network.target

[Service]
Type=simple
User=mysqlrouter
Group=mysqlrouter
# Wait for the local MySQL node to be ONLINE in Group Replication before
# starting Router. Polls for up to 90 s (45 × 2 s); exits early on success.
ExecStartPre=+/bin/bash -c 'for i in $(seq 1 45); do state=$(mysql -uroot -Nse "SELECT member_state FROM performance_schema.replication_group_members WHERE member_host=@@report_host LIMIT 1" 2>/dev/null); [ "$state" = "ONLINE" ] && exit 0; sleep 2; done; exit 1'
ExecStart=/usr/bin/mysqlrouter -c /etc/mysqlrouter/{{ cluster_name }}/mysqlrouter.conf
Restart=always
# 10s gap between restarts — gives MySQL time to stabilise before Router reconnects.
RestartSec=10
# Cap restart rate: max 5 starts per 5 minutes to avoid a crash loop.
StartLimitIntervalSec=300
StartLimitBurst=5
# ExecStartPre can take up to 90 s polling for GR ONLINE. Give the full
# pre-check budget plus 120 s for mysqlrouter itself to initialise.
TimeoutStartSec=210
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
