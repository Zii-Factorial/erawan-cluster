#!/bin/bash
# Auto-heals a stuck GR applier channel and rejoins the cluster.
# Runs as a systemd timer every {{ gr_watchdog_interval_seconds }}s. Safe to run repeatedly.

STATE=$(mysql -uroot -Nse \
  "SELECT member_state FROM performance_schema.replication_group_members \
   WHERE member_host = @@report_host LIMIT 1" 2>/dev/null)

if [[ "$STATE" == "ONLINE" || "$STATE" == "RECOVERING" ]]; then
  exit 0
fi

logger -t erawan-gr-watchdog "GR state is '${STATE:-unknown}' — attempting recovery"

# Run each statement independently so a missing channel or already-stopped GR
# does not abort the sequence before START GROUP_REPLICATION is reached.
mysql -uroot 2>/dev/null -e "STOP GROUP_REPLICATION"                                       || true
mysql -uroot 2>/dev/null -e "RESET REPLICA ALL FOR CHANNEL 'group_replication_applier'"   || true
mysql -uroot 2>/dev/null -e "START GROUP_REPLICATION"

sleep 10
NEW_STATE=$(mysql -uroot -Nse \
  "SELECT member_state FROM performance_schema.replication_group_members \
   WHERE member_host = @@report_host LIMIT 1" 2>/dev/null)
logger -t erawan-gr-watchdog "GR state after recovery attempt: '${NEW_STATE:-unknown}'"

# After a successful rejoin, restart MySQL Router so it re-discovers the
# current cluster topology and re-binds port 6446 (R/W) cleanly.
# Without this, Router may retain stale state and refuse R/W connections.
if [[ "$NEW_STATE" == "ONLINE" ]]; then
  logger -t erawan-gr-watchdog "Restarting MySQL Router to re-discover cluster topology"
  systemctl restart {{ router_service_name }} 2>/dev/null || true
fi
