[Unit]
Description=Patroni PostgreSQL high availability
After=network-online.target etcd.service
Wants=network-online.target etcd.service

[Service]
Type=simple
User=postgres
Group=postgres
Environment=PATH=/usr/local/bin:/usr/bin:/bin
ExecStart={{ erawan_patroni_bin_path }} {{ patroni_config_path }}
ExecReload=/bin/kill -s HUP $MAINPID
KillMode=process
TimeoutSec=30
Restart=on-failure
RestartSec=5
LimitNOFILE=262144

[Install]
WantedBy=multi-user.target
